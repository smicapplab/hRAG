		"@langchain/google-genai": "^2.1.27",
		"@langchain/ollama": "^1.2.6",
		"@langchain/openai": "^1.4.4",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"express": "^5.2.1",
		"jose": "^6.2.2",
		"langchain": "^1.3.3",
		"lucide-svelte": "^1.0.1",
		"mode-watcher": "^1.1.0",
		"pg": "^8.20.0",
		"tailwind-merge": "^3.5.0",
